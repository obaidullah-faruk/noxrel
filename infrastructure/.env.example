# Local-dev credentials for the infrastructure stack (docker-compose.infra.yml).
#
# Copy this file to `.env` in the same directory before starting infra:
#     cp infrastructure/.env.example infrastructure/.env
#
# Docker Compose auto-loads `infrastructure/.env` when you run compose from the
# infrastructure/ directory. The values below are DEV-ONLY — in production these
# are sourced from AWS Secrets Manager, never from a committed file.

# Elasticsearch / Kibana / APM / Fleet / OTel Collector / Fluent Bit / Grafana datasource.
# Single shared dev password for the `elastic` and `kibana_system` users.
ELASTIC_PASSWORD=noxrel_dev

# PostgreSQL — superuser `noxrel` used by every Django service locally.
# Must match DB_PASSWORD in services/*/.env (DB_USER=noxrel there).
POSTGRES_PASSWORD=noxrel

# Grafana admin login.
GRAFANA_ADMIN_PASSWORD=admin
