# Server-side: Kong API gateway URL (used in Next.js route handlers / server components)
# Docker Compose: http://localhost:8100 (Kong). K8s on macOS/Windows Docker driver: same
# URL + `make k8s-ingress-forward`. K8s on Linux (kvm/qemu): http://$(minikube ip)
API_GATEWAY_URL=http://localhost:8100

# Client-side: Kong API gateway URL (exposed to the browser)
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8100

# Server-side: streaming-service direct URL (used in Next.js route handlers)
STREAMING_SERVICE_URL=http://localhost:3002
