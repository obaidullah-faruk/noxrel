# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_CONSUMER_GROUP=transcode-worker

# AWS / LocalStack S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_ENDPOINT_URL=http://localstack:4566
S3_RAW_BUCKET=raw-videos
S3_TRANSCODED_BUCKET=transcoded-videos
S3_THUMBNAIL_BUCKET=thumbnails

# CDN — LocalStack S3 for local dev, real CloudFront distribution URL for production
# e.g. production: https://d1234abcd.cloudfront.net
CLOUDFRONT_BASE_URL=http://localstack:4566/transcoded-videos

# FFmpeg tuning
FFMPEG_PRESET=fast
FFMPEG_CRF=23
HLS_SEGMENT_DURATION=6

# Retry policy
TRANSCODE_MAX_RETRIES=3

DEBUG=false
LOG_LEVEL=INFO
