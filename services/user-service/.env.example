# Django core
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=true
ALLOWED_HOSTS=*
LOG_LEVEL=INFO

# PostgreSQL — matches infrastructure/docker-compose.infra.yml credentials
DB_NAME=platform
DB_USER=platform
DB_PASSWORD=platform_dev
DB_HOST=postgres
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# JWT RS256 keys — leave empty to use built-in dev defaults
# In production: set these to the actual PEM strings from your secrets manager
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Google OAuth2 (optional for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Dev admin (created by: python manage.py create_dev_admin)
DEV_ADMIN_EMAIL=admin@admin.com
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin1234
