PORT=3002
NODE_ENV=development
LOG_LEVEL=info

# AWS / LocalStack S3
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_TRANSCODED_BUCKET=transcoded-videos

# CDN — Use host-accessible URL for local dev so browsers can reach HLS files.
# LocalStack is reachable at localhost:4566 from the host, not localstack:4566.
# Production: https://d1234abcd.cloudfront.net
CDN_BASE_URL=http://localhost:4566

# Redis
REDIS_URL=redis://redis:6379

# Kafka — comma-separated list of brokers
KAFKA_BROKERS=kafka:29092

# RS256 public key — matches the dev default in user-service/config/settings.py
# In production: inject from Secrets Manager
