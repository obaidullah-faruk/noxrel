# Django core
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=true
ALLOWED_HOSTS=*
LOG_LEVEL=INFO

# PostgreSQL — matches infrastructure/docker-compose.infra.yml credentials
DB_NAME=video_service
DB_USER=platform
DB_PASSWORD=platform_dev
DB_HOST=postgres
DB_PORT=5432

# Redis (db index 1 — does not collide with user-service on db 0)
REDIS_URL=redis://redis:6379/1

# JWT RS256 public key — must match User Service's private key
# Leave empty to use built-in dev default (matches user-service dev key)
JWT_PUBLIC_KEY=

# AWS / LocalStack S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_ENDPOINT_URL=http://localstack:4566
S3_RAW_BUCKET=raw-videos
S3_TRANSCODED_BUCKET=transcoded-videos
S3_THUMBNAIL_BUCKET=thumbnails

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Internal API key (used by other services calling /internal/* endpoints)
INTERNAL_API_KEY=dev-internal-key
