PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL — live-service owns its own logical database
DATABASE_URL=postgres://noxrel:noxrel@postgres:5432/live_service

# Redis (viewer presence ZSETs, chat rate-limit keys, socket.io pub/sub adapter)
REDIS_URL=redis://redis:6379

# MongoDB (chat message log)
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=live_service

# Kafka — comma-separated list of brokers
KAFKA_BROKERS=kafka:29092

# AWS / LocalStack S3
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_LIVE_BUCKET=live-segments

# CDN base for stored manifest URLs. Manifests use RELATIVE segment URIs, so
# this only forms the hls_master_url / replay_url values handed to clients.
# Local dev: browsers reach LocalStack at localhost:4566, not localstack:4566.
# Production: https://d1234abcd.cloudfront.net
CDN_BASE_URL=http://localhost:4566/live-segments

# nginx-rtmp ingest edge — FFmpeg pulls from here; control endpoint drops publishers
NGINX_RTMP_URL=rtmp://nginx-rtmp:1935/live
NGINX_CONTROL_URL=http://nginx-rtmp:8080/control

# video-service internal endpoint (replay registration) + shared internal key
VIDEO_SERVICE_INTERNAL_URL=http://video-service:8001
INTERNAL_API_KEY=dev-internal-key

# RS256 public key — matches the dev default in user-service/config/settings.py
# In production: inject from Secrets Manager
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAkc/Qf9ZM0Vc6fCfqxQSi\nrAfXRfuRbHwWflmnZPHEc9LALftZ3G+1NfnFtZgkIrHbc5bPzryEJgLrDO+7hbF3\n6tfiF1aaCc62HNgwFx0dJN8zNtIx6edZc5pQ9hcO68NZvzN/fI3PJeXah9JHZ+eI\nSDc4/5JUZGXy0utx9Id9RESZb360fLBMG1OmdPZQ9x/Alb7fkLsKJRWfSUW0EWBO\n/wH5sBmi31zx8RgEbUXNLAG07HbxrtT4jty2Vf9p43NSqjGNUIxYVUVq7BNwQMPQ\ncxFBTxhSLveOj1TvNXK1dwo3PCeQNuK6IqepDG1j6xqWfGPGFmZL9P013qut1qXr\nsQIDAQAB\n-----END PUBLIC KEY-----

# Live encoding
# Comma-separated rendition ladder. Dev can use a lighter ladder (e.g. 720p,480p);
# compose/prod use the full four.
RENDITIONS=1080p,720p,480p,360p
MAX_STREAM_DURATION_HOURS=12
