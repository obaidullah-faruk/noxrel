# ── billing-service environment ──────────────────────────────────────────────
# Copy to .env and fill in secrets before running.
#   cp services/billing-service/.env.example services/billing-service/.env

# Django/FastAPI core
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production
LOG_LEVEL=INFO

# PostgreSQL — matches infrastructure/docker-compose.infra.yml credentials
DB_HOST=postgres
DB_PORT=5432
DB_NAME=billing_service
DB_USER=noxrel
DB_PASSWORD=noxrel   # matches infrastructure/docker-compose.infra.yml POSTGRES_PASSWORD

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CONSUMER_GROUP=billing-service

# Stripe — replace with your real Stripe test-mode keys
# Get them at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# URLs Stripe redirects to after checkout (must be reachable from the user's browser)
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# JWT public key (RS256) — billing-service only verifies tokens, never issues them.
# Leave empty to use the built-in dev default (matches user-service dev key).
JWT_PUBLIC_KEY=

# Shared secret for gateway-header auth (x-user-id / x-user-roles bypass).
# Must match the value set in the API gateway. Leave empty to disable the header path.
GATEWAY_SHARED_SECRET=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
SERVICE_NAME=billing-service
